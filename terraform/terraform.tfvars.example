# ─── ShopMesh Terraform Variables ─────────────────────────────────────────
# Copy to terraform.tfvars and fill in your values

aws_region   = "us-east-1"
project_name = "shopmesh"
environment  = "prod"

# VPC
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]
availability_zones   = ["us-east-1a", "us-east-1b"]

# EC2
# AMI is resolved automatically (latest Ubuntu 22.04 LTS Jammy via data source)
frontend_instance_type = "t3.small"
backend_instance_type  = "t3.medium"
ec2_key_pair_name      = ""             # Set to your key pair name for SSH access

# Auto Scaling
frontend_asg_min     = 1
frontend_asg_desired = 2
frontend_asg_max     = 4
backend_asg_min      = 1
backend_asg_desired  = 2
backend_asg_max      = 4

# CloudFront
cloudfront_price_class = "PriceClass_100"

# Application
docker_image_tag = "latest"
# ECR repositories are automatically created by terraform — no manual setup needed.
alert_email = "ops@example.com"
